    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "esbuild-decorators": "^1.0.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
